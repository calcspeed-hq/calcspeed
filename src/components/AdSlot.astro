---
interface Props {
  slot: 1 | 2 | 3;
  label?: string;
}
const { slot, label } = Astro.props;

const labels: Record<number, string> = {
  1: 'Above Calculator',
  2: 'Below Calculator / Above FAQ',
  3: 'Below FAQ',
};
---

<!-- ADSENSE SLOT {slot}: {labels[slot]} -->
<!-- Replace this div with your actual AdSense ad unit code -->
<div
  class="w-full min-h-[90px] bg-gray-50 border border-dashed border-gray-200 rounded-lg flex items-center justify-center my-6"
  aria-label="Advertisement"
  data-ad-slot={slot}
>
  <span class="text-xs text-gray-300 font-mono select-none">
    AD SLOT {slot} &mdash; {label || labels[slot]}
  </span>
</div>
